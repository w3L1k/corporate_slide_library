# Local backend
HOST=127.0.0.1
PORT=3001
# Optional. Leave empty to use the bundled ./data demo catalog.
SLIDE_LIBRARY_PATH=
# Comma-separated origins allowed to call the API directly.
CORS_ORIGINS=https://localhost:3000,http://localhost:3000,http://127.0.0.1:3000
# Development/pilot-only reindex endpoint. Keep disabled outside a controlled pilot.
ENABLE_ADMIN_REINDEX=false

# Frontend; leave empty in local development to use Vite's same-origin /api proxy.
VITE_API_BASE_URL=
# Optional dev proxy override when the backend is not at the default address.
VITE_API_PROXY_TARGET=http://127.0.0.1:3001
